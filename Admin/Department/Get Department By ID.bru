meta {
  name: Get Department By ID
  type: http
  seq: 3
}

get {
  url: {{host}}/admin/faculty/:facultyID/departments/:deptID
  body: none
  auth: inherit
}

params:path {
  facultyID: 10
  deptID: 1
}

body:json {
  {
    "campus_name": "บางแสน"
  }
}

vars:pre-request {
  id: 1
}

settings {
  encodeUrl: true
  timeout: 0
}
