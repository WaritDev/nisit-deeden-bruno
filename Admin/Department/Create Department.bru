meta {
  name: Create Department
  type: http
  seq: 1
}

post {
  url: {{host}}/admin/campus/:campusID/faculty/:facultyID/department
  body: json
  auth: inherit
}

params:path {
  campusID: 1
  facultyID: 10
}

body:json {
  {
    "department_name": "วิศวกรรมเคมี"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
